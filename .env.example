# Twilio credentials — find these in your Twilio Console
# https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Twilio "From" phone number (must be a number Twilio can send from)
TWILIO_FROM_NUMBER=+17205551234

# Public URL of your deployed server + /answer (TwiML webhook)
# e.g. https://your-app.railway.app/answer
ANSWER_URL=https://your-app.railway.app/answer

# Pet Releaf payment update page
PAYMENT_UPDATE_URL=https://www.petreleaf.com/account

# Optional: a random string you make up — add to Smartrr webhook URL as ?secret=xxx
# e.g. https://your-app.railway.app/billing-failure?secret=abc123xyz
WEBHOOK_SECRET=make_up_a_random_string_here

# Where to store billing failures + daily call history (persistent storage recommended)
# For Render/Railway, set this to a writable mounted disk path if possible.
DB_PATH=billing_failures.db

# If true, the server may place a call when Smartrr POSTs /billing-failure
# (only when a reminder is due — see REMINDER_INTERVAL_DAYS).
CALL_ON_WEBHOOK=false

# Minimum days between voicemail reminders for the same customer (while still failed).
REMINDER_INTERVAL_DAYS=30

# Optional: override the spoken voicemail text (one message for all customers).
# VOICEMAIL_MESSAGE=Hi, this is Pet Releaf. Please update your payment method. Thank you.

# If true, start a background worker thread that scans for due reminders.
# Recommended only when you have a single running instance of this server.
SCHEDULER_ENABLED=false

# How often the worker runs (seconds). 86400 = once per day (it only calls people due by REMINDER_INTERVAL_DAYS).
DAILY_CALL_INTERVAL_SECONDS=86400

# Max number of customers to call per daily run (safety limit).
DAILY_CALL_MAX_BATCH=200

# Safety cutoff: stop reminders for failures older than N days (no success/cancel webhook).
# Use a large value if you want monthly reminders for a long time.
MAX_FAILURE_AGE_DAYS=365

# Optional: separate secret for manually triggering /run-daily-calls.
# If empty, the server reuses WEBHOOK_SECRET.
DAILY_JOB_SECRET=

# Smartrr webhooks (same WEBHOOK_SECRET in ?secret= or X-Smartrr-Secret):
# - POST /billing-failure       — failed payment (reminder calls)
# - POST /billing-success       — payment succeeded (stop reminders)
# - POST /subscription-cancel   — subscription cancelled (stop reminders)
